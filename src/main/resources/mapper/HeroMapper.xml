<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.HeroMapper">

    <resultMap id="HeroResultMap" type="com.example.demo.pojo.Hero">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="gender" property="gender"/>
        <result column="role" property="role"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="findById" resultMap="HeroResultMap">
        SELECT id, name, gender, `role`, create_time
        FROM hero
        WHERE id = #{id}
        LIMIT 1
    </select>

    <select id="countByIds" resultType="java.lang.Integer">
        SELECT COUNT(1)
        FROM hero
        WHERE id IN
        <foreach collection="heroIds" item="heroId" open="(" separator="," close=")">
            #{heroId}
        </foreach>
    </select>

    <select id="listHeroes" resultType="com.example.demo.dto.HeroVO">
        SELECT id,
               name,
               gender,
               `role` AS role
        FROM hero
        WHERE 1 = 1
        <if test="keyword != null and keyword != ''">
            AND (
                name LIKE CONCAT('%', #{keyword}, '%')
                OR `role` LIKE CONCAT('%', #{keyword}, '%')
            )
        </if>
        <if test="gender != null">
            AND gender = #{gender}
        </if>
        <if test="role != null and role != ''">
            AND `role` = #{role}
        </if>
        ORDER BY id ASC
    </select>

</mapper>
