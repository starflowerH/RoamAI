<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.AgentMapper">

    <resultMap id="AgentResultMap" type="com.example.demo.pojo.Agent">
        <id column="id" property="id"/>
        <result column="agent_name" property="agentName"/>
        <result column="provider" property="provider"/>
        <result column="app_id" property="appId"/>
        <result column="api_key" property="apiKey"/>
        <result column="agent_id" property="agentId"/>
        <result column="base_url" property="baseUrl"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="findById" resultMap="AgentResultMap">
        SELECT *
        FROM t_agent_config
        WHERE id = #{id}
        LIMIT 1
    </select>

    <select id="findByAgentId" resultMap="AgentResultMap">
        SELECT *
        FROM t_agent_config
        WHERE agent_id = #{agentId}
        LIMIT 1
    </select>

    <select id="findByAppId" resultMap="AgentResultMap">
        SELECT *
        FROM t_agent_config
        WHERE app_id = #{appId}
        LIMIT 1
    </select>

    <select id="findByName" resultMap="AgentResultMap">


        SELECT *
        FROM t_agent_config
        WHERE agent_name = #{agentName}
        LIMIT 1
    </select>

    <select id="listEnabled" resultMap="AgentResultMap">
        SELECT *
        FROM t_agent_config
        WHERE status = 1
        ORDER BY id ASC
    </select>

    <select id="listAll" resultMap="AgentResultMap">
        SELECT *
        FROM t_agent_config
        ORDER BY id DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_agent_config (
            agent_name,
            provider,
            app_id,
            api_key,
            agent_id,
            base_url,
            status
        ) VALUES (
            #{agentName},
            #{provider},
            #{appId},
            #{apiKey},
            #{agentId},
            #{baseUrl},
            #{status}
        )
    </insert>

    <update id="updateStatus">
        UPDATE t_agent_config
        SET status = #{status}
        WHERE id = #{id}
    </update>

</mapper>
